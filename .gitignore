# Rust build output
/target
**/*.rs.bk

# Local reference oracle: the pinned Alloy jar, scratch models, extracted
# license texts, and third-party source kept only for reference. Fully
# reproducible from docs/reference/alloy6-reference.md (jar pinned by SHA).
# Never committed — also keeps third-party Java source out of our tree (legal hygiene).
/oracle/

# Conformance corpora (mt-007): vendored .als models used as the conformance
# oracle's test corpus. Never committed (ADR-0006: local-only — portus-63
# aggregates GPL-3.0 and no-license sources). Fully reproducible from
# docs/reference/corpora.md (each corpus pinned by commit SHA / DOI / tag)
# via scripts/fetch-corpora.sh.
/corpus/

# OS cruft
.DS_Store

# Jar-probe harnesses + probe models (DumpK2 etc.): local evidence for the
# pinned facts in docs/reference/*; recreatable from those docs' descriptions.
/scratchpad/
